{
  "name": "sports-bet-coach",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Sharp Sheet Tips — daily sports betting recommendations synced with Google Sheets and ESPN schedules",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --prefix client",
    "dev:server": "tsx watch server/index.ts",
    "build": "npm run build --prefix client",
    "build:pages": "tsx server/scripts/export-pages-data.ts && npm run build --prefix client",
    "sync": "tsx server/scripts/sync-sheets.ts",
    "test:confidence": "tsx server/scripts/test-confidence.ts",
    "test:game-association": "tsx server/tests/gameAssociation.test.ts",
    "test:recommendation-rules": "tsx server/tests/recommendationRules.test.ts",
    "test:pick-parser": "tsx server/tests/pickBetParser.test.ts",
    "test:tracking": "tsx server/tests/tracking.test.ts",
    "test:dratings": "tsx server/tests/dratingsTrends.test.ts",
    "start": "tsx server/index.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "express": "^4.21.2",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}